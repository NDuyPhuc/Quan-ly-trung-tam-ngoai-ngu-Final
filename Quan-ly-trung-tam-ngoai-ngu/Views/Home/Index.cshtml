@model HomePageViewModel
@{
    var heroImage = Url.Content("~/images/placeholders/anhnen.jpg");
    var featuredCourseImages = new[]
    {
        Url.Content("~/images/placeholders/course1.jpg"),
        Url.Content("~/images/placeholders/course2.jpg"),
        Url.Content("~/images/placeholders/course3.jpg")
    };
    var featuredCourseIndex = 0;
    var latestNewsImages = new[]
    {
        Url.Content("~/images/placeholders/news1.jpg"),
        Url.Content("~/images/placeholders/news2.jpg"),
        Url.Content("~/images/placeholders/news3.jpg")
    };
    var latestNewsIndex = 0;
    var coreValues = new[]
    {
        new { Title = "Chất lượng thực học", Description = "Cam kết kết quả dựa trên lộ trình học rõ ràng và có đo lường." },
        new { Title = "Tận tâm", Description = "Đồng hành với học viên ở mọi chặng của quá trình học tập." },
        new { Title = "Sáng tạo", Description = "Liên tục cập nhật phương pháp giảng dạy và cách vận hành hiện đại." },
        new { Title = "Kết nối", Description = "Xây dựng cộng đồng học tập văn minh, hỗ trợ lẫn nhau." }
    };
    var advantages = new[]
    {
        "Theo dõi tiến độ học tập 24/7 qua hệ thống.",
        "Kho tài liệu số tập trung, không bị phân mảnh theo từng bộ phận.",
        "Tương tác trực tiếp với giáo viên và giáo vụ nhanh hơn.",
        "Thông tin lớp, học phí và lịch học được đồng bộ rõ ràng."
    };
}

<section id="trang-chu" class="landing-hero-section">
    <div class="container">
        <div class="landing-hero-shell">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6">
                    <span class="landing-label">NorthStar English</span>
                    <h1 class="landing-hero-title">@Model.HeroTitle</h1>
                    <p class="landing-hero-copy">@Model.HeroSubtitle</p>
                    <div class="landing-hero-actions">
                        <a class="btn btn-primary btn-lg" href="#khoa-hoc">Xem khóa học</a>
                        <a class="btn btn-outline-primary btn-lg" href="#lien-he">Đăng ký tư vấn</a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="landing-hero-media">
                        <img src="@heroImage" alt="Minh họa lớp học NorthStar English" />
                        <div class="landing-hero-overlay">
                            <span class="overlay-icon"><i class="bi bi-stars"></i></span>
                            <div>
                                <strong>Giảng viên đồng hành sát tiến độ</strong>
                                <span>Lộ trình học, xếp lớp, học phí và tư vấn được gom về một trải nghiệm rõ ràng hơn.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-4">
                @foreach (var item in Model.HighlightStats)
                {
                    <div class="col-md-6 col-xl-3">
                        <div class="stat-card stat-@item.AccentClass home-highlight-card">
                            <div class="stat-icon"><i class="@item.Icon"></i></div>
                            <div class="stat-content">
                                <span>@item.Title</span>
                                <strong>@item.Value</strong>
                                <p>@item.Description</p>
                                @if (!string.IsNullOrWhiteSpace(item.Trend))
                                {
                                    <small>@item.Trend</small>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section id="gioi-thieu" class="landing-section">
    <div class="container">
        <div class="landing-section-header centered">
            <h2>@Model.AboutTitle</h2>
            <p>@Model.AboutSubtitle</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="landing-panel soft">
                    <div class="panel-heading-with-icon">
                        <span class="panel-heading-icon"><i class="bi bi-gem"></i></span>
                        <h3>Giá trị cốt lõi</h3>
                    </div>
                    <div class="value-grid">
                        @foreach (var item in coreValues)
                        {
                            <div class="value-card">
                                <h4>@item.Title</h4>
                                <p>@item.Description</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="landing-panel accent">
                    <h3>@Model.AboutHighlightTitle</h3>
                    <p>@Model.AboutHighlightBody</p>
                    <ul class="accent-list">
                        @foreach (var item in advantages)
                        {
                            <li><i class="bi bi-check-circle-fill"></i>@item</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="khoa-hoc" class="landing-section muted">
    <div class="container">
        <div class="landing-section-header between">
            <div>
                <h2>Khóa Học Nổi Bật</h2>
                <p>Xem nhanh các lộ trình đang được quan tâm nhiều nhất trước khi vào trang danh mục chi tiết.</p>
            </div>
            <a class="section-link" asp-controller="Courses" asp-action="Index">Xem tất cả khóa học <i class="bi bi-arrow-right"></i></a>
        </div>

        <div class="row g-4">
            @foreach (var course in Model.FeaturedCourses)
            {
                var courseImage = featuredCourseIndex < featuredCourseImages.Length
                    ? featuredCourseImages[featuredCourseIndex]
                    : AppUi.CourseImageUrl(course.Slug);
                featuredCourseIndex++;

                <div class="col-lg-4">
                    <article class="catalog-media-card h-100">
                        <div class="catalog-media-thumb">
                            <img src="@courseImage" alt="@course.Name" />
                            <span class="catalog-chip catalog-chip-primary">@AppUi.CourseTag(course.Slug)</span>
                            <span class="catalog-chip catalog-chip-light">@course.Level</span>
                        </div>
                        <div class="catalog-media-body">
                            <div class="catalog-meta-row">
                                <span>@course.ScheduleSummary</span>
                                <span>@course.Duration</span>
                            </div>
                            <h3>@course.Name</h3>
                            <p>@course.ShortDescription</p>
                            <div class="catalog-card-footer">
                                <strong>@AppUi.Currency(course.TuitionFee)</strong>
                                <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Slug">Xem chi tiết</a>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section id="lop-hoc" class="landing-section">
    <div class="container">
        <div class="landing-section-header centered">
            <h2>Lớp Học Và Lịch Khai Giảng</h2>
            <p>Lịch học linh hoạt, giáo viên phụ trách rõ ràng và trạng thái lớp được hiển thị ngay trên trang chủ.</p>
        </div>

        <div class="schedule-table-card">
            <div class="schedule-table-head">
                <div>Mã lớp</div>
                <div>Khóa học</div>
                <div>Thời gian</div>
                <div>Giáo viên</div>
                <div>Trạng thái</div>
                <div></div>
            </div>
            @foreach (var item in Model.OpenClasses)
            {
                <div class="schedule-table-row">
                    <div class="schedule-cell">
                        <span class="mobile-label">Mã lớp</span>
                        <strong>@item.Code</strong>
                    </div>
                    <div class="schedule-cell">
                        <span class="mobile-label">Khóa học</span>
                        @item.CourseName
                    </div>
                    <div class="schedule-cell">
                        <span class="mobile-label">Thời gian</span>
                        @item.Schedule
                    </div>
                    <div class="schedule-cell">
                        <span class="mobile-label">Giáo viên</span>
                        <div class="teacher-inline">
                            <span class="teacher-avatar @AppUi.ToneClass(item.TeacherName)">@AppUi.TeacherInitials(item.TeacherName)</span>
                            <span>@item.TeacherName</span>
                        </div>
                    </div>
                    <div class="schedule-cell">
                        <span class="mobile-label">Trạng thái</span>
                        <span class="badge @AppUi.StatusBadgeClass(item.Status)">@item.Status</span>
                    </div>
                    <div class="schedule-cell action">
                        <a class="btn btn-primary btn-sm" href="#lien-he">Nhận tư vấn</a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="tin-tuc" class="landing-section muted">
    <div class="container">
        <div class="landing-section-header between">
            <div>
                <h2>Tin Tức Và Sự Kiện</h2>
                <p>Các thông báo khai giảng, workshop và bài viết mới được trình bày theo kiểu thẻ ảnh gọn và dễ đọc.</p>
            </div>
            <a class="section-link" asp-controller="News" asp-action="Index">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>

        <div class="row g-4">
            @foreach (var article in Model.LatestNews)
            {
                var newsImage = latestNewsIndex < latestNewsImages.Length
                    ? latestNewsImages[latestNewsIndex]
                    : AppUi.NewsImageUrl(article.Slug);
                latestNewsIndex++;

                <div class="col-lg-4">
                    <article class="news-media-card h-100">
                        <div class="news-media-thumb">
                            <img src="@newsImage" alt="@article.Title" />
                        </div>
                        <div class="news-media-body">
                            <div class="news-meta-top">
                                <span>@article.Category</span>
                                <span>@article.PublishedOn.ToString("dd/MM/yyyy")</span>
                            </div>
                            <h3>@article.Title</h3>
                            <p>@article.Summary</p>
                            <a asp-controller="News" asp-action="Details" asp-route-id="@article.Slug">Đọc chi tiết</a>
                        </div>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section id="lien-he" class="landing-section">
    <div class="container">
        <div class="landing-section-header between align-start">
            <div>
                <h2>@Model.ContactSectionTitle</h2>
                <p>@Model.ContactSectionSubtitle</p>
            </div>
            <a class="section-link" asp-controller="Contact" asp-action="Index">Mở trang liên hệ đầy đủ <i class="bi bi-arrow-right"></i></a>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="contact-info-stack">
                    <div class="contact-info-card">
                        <span class="contact-info-icon"><i class="bi bi-envelope-paper"></i></span>
                        <strong>Email nhận yêu cầu</strong>
                        <p>@Model.SupportEmail<br />Mọi biểu mẫu liên hệ đều được ghi nhận vào hồ sơ tư vấn nội bộ. Nếu SMTP được cấu hình, thông tin cũng sẽ được gửi thêm về hộp thư này.</p>
                    </div>
                    <div class="contact-info-card">
                        <span class="contact-info-icon"><i class="bi bi-telephone-forward"></i></span>
                        <strong>Hotline tư vấn</strong>
                        <p>@Model.SupportPhone<br />Ưu tiên gọi lại trong ngày cho các yêu cầu xếp lớp và tư vấn đầu vào.</p>
                    </div>
                    <div class="contact-info-card">
                        <span class="contact-info-icon"><i class="bi bi-calendar-check"></i></span>
                        <strong>Khung giờ hỗ trợ</strong>
                        <p>@Model.SupportHours<br />Có thể tư vấn học trực tiếp hoặc online.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="form-display-card contact-home-card">
                    <div class="landing-section-header contact-header">
                        <div>
                            <h2>@Model.ContactFormTitle</h2>
                            <p>@Model.ContactFormSubtitle</p>
                        </div>
                    </div>
                    @await Html.PartialAsync("~/Views/Shared/Partials/_ContactInquiryForm.cshtml", Model.ContactForm, new ViewDataDictionary(ViewData)
                    {
                        ["ReturnUrl"] = "/#lien-he",
                        ["SubmitLabel"] = "Gửi thông tin liên hệ",
                        ["SupportEmail"] = Model.SupportEmail
                    })
                </div>
            </div>
        </div>
    </div>
</section>
