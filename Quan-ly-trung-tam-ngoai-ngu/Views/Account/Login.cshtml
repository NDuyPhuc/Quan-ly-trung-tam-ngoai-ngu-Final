@model LoginViewModel

<section class="auth-showcase-section">
    <div class="container">
        <div class="auth-showcase-layout">
            <div class="auth-showcase-visual">
                <img src="@AppUi.PublicImageUrl("login")" alt="Minh họa đăng nhập NorthStar English" />
                <div class="auth-showcase-overlay">
                    <span class="auth-spotlight-pill">Học thuật xuất sắc</span>
                    <h1>Mở lại không gian quản trị cùng NorthStar English</h1>
                    <p>Trang này chỉ dành cho tài khoản nội bộ của Admin, Staff và Teacher để truy cập khu quản trị từ dữ liệu SQL Server.</p>
                    <div class="auth-avatar-group">
                        <span class="teacher-avatar tone-blue">MA</span>
                        <span class="teacher-avatar tone-gold">MK</span>
                        <span class="teacher-avatar tone-indigo">TV</span>
                        <strong>Dữ liệu dashboard, lớp học, học viên và học phí đang được đồng bộ từ cơ sở dữ liệu.</strong>
                    </div>
                </div>
            </div>

            <div class="auth-showcase-card">
                <span class="auth-card-kicker">Chào mừng quay lại</span>
                <h2>@Model.Title</h2>
                <p class="page-subtitle">@Model.Subtitle</p>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                {
                    <div class="alert alert-warning">@ViewData.ModelState[string.Empty]!.Errors.First().ErrorMessage</div>
                }

                <form asp-action="Login" method="post" class="row g-4">
                    <div class="col-12">
                        <label asp-for="Email" class="form-label"></label>
                        <div class="input-icon">
                            <i class="bi bi-envelope-fill"></i>
                            <input asp-for="Email" class="form-control" placeholder="email@domain.com hoặc username" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center">
                            <label asp-for="Password" class="form-label mb-0"></label>
                            <a asp-action="ForgotPassword" class="auth-inline-link">Quên mật khẩu?</a>
                        </div>
                        <div class="input-icon">
                            <i class="bi bi-lock-fill"></i>
                            <input asp-for="Password" class="form-control" placeholder="********" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check auth-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary w-100 auth-submit-btn" type="submit">Đăng nhập tài khoản <i class="bi bi-arrow-right"></i></button>
                    </div>
                </form>


                <p class="auth-switch-copy">Bạn cần được trung tâm tư vấn? <a asp-action="Register">Đăng ký tư vấn</a></p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
