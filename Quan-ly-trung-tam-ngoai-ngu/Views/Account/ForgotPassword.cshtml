@model ForgotPasswordViewModel

<section class="auth-showcase-section">
    <div class="container">
        <div class="auth-showcase-layout compact">
            <div class="auth-showcase-visual forgot">
                <img src="@AppUi.PublicImageUrl("forgot")" alt="Minh họa khôi phục mật khẩu" />
                <div class="auth-showcase-overlay">
                    <span class="auth-spotlight-pill">Khôi phục truy cập</span>
                    <h1>Nhập email để nhận hướng dẫn lấy lại mật khẩu</h1>
                    <p>Trang quên mật khẩu được đồng bộ cùng phong cách visual của đăng nhập và đăng ký để trải nghiệm không bị đứt đoạn.</p>
                </div>
            </div>

            <div class="auth-showcase-card">
                <span class="auth-card-kicker">Quên mật khẩu</span>
                <h2>@Model.Title</h2>
                <p class="page-subtitle">@Model.Subtitle</p>

                <form asp-action="ForgotPassword" method="post" class="row g-4">
                    <div class="col-12">
                        <label asp-for="Email" class="form-label"></label>
                        <div class="input-icon">
                            <i class="bi bi-envelope-fill"></i>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-12 d-flex flex-wrap gap-2">
                        <button class="btn btn-primary auth-submit-btn" type="submit">Gửi yêu cầu khôi phục <i class="bi bi-arrow-right"></i></button>
                        <a class="btn btn-outline-primary" asp-action="Login">Quay lại đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
