@model AboutPageViewModel

<section class="page-section page-section-spacious">
    <div class="container">
        @await Html.PartialAsync("~/Views/Shared/Partials/_Breadcrumbs.cshtml", Model.Breadcrumbs)

        <div class="catalog-hero-card">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6">
                    <span class="landing-label">Giới thiệu trung tâm</span>
                    <h1>@Model.Title</h1>
                    <p class="page-subtitle">@Model.Subtitle</p>
                    <div class="hero-chip-row">
                        <span class="info-pill">Học thuật rõ ràng</span>
                        <span class="info-pill">Quản trị minh bạch</span>
                        <span class="info-pill">Sẵn sàng mở rộng</span>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="catalog-hero-media">
                        <img src="@AppUi.PublicImageUrl("about")" alt="Minh họa về NorthStar English" />
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-1">
            @foreach (var item in Model.Achievements)
            {
                <div class="col-md-4">
                    <div class="achievement-strip-card">
                        <span class="achievement-icon"><i class="@item.Icon"></i></span>
                        <strong>@item.Value</strong>
                        <h3>@item.Title</h3>
                        <p>@item.Description</p>
                    </div>
                </div>
            }
        </div>

        <div class="row g-4 mt-1">
            <div class="col-lg-6">
                <div class="landing-panel soft h-100">
                    <div class="panel-heading-with-icon">
                        <span class="panel-heading-icon"><i class="bi bi-gem"></i></span>
                        <h3>Giá trị cốt lõi</h3>
                    </div>
                    <div class="value-grid">
                        @foreach (var value in Model.CoreValues)
                        {
                            <div class="value-card">
                                <h4>@value</h4>
                                <p>Nội dung được trình bày lại theo dạng thẻ để gần hơn với giao diện mẫu và dễ quét thông tin hơn.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="landing-panel accent h-100">
                    <h3>Lợi thế hệ thống</h3>
                    <p>Các phân hệ được tách trang riêng theo từng nút menu, nhưng vẫn giữ cảm giác liền mạch giống cùng một bộ giao diện.</p>
                    <ul class="accent-list">
                        @foreach (var item in Model.Advantages)
                        {
                            <li><i class="bi bi-check-circle-fill"></i>@item</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
