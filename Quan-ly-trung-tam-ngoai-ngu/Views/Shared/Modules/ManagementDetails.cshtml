@model ManagementDetailsPageViewModel

<div class="app-page">
    @await Html.PartialAsync("~/Views/Shared/Partials/_Breadcrumbs.cshtml", Model.Breadcrumbs)
    <div class="page-header">
        <div>
            <h1>@Model.Title</h1>
            <p class="page-subtitle">@Model.Subtitle</p>
        </div>
        @if (Model.Actions.Any())
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var action in Model.Actions)
                {
                    <a href="@action.Url" class="@action.CssClass"><i class="@action.Icon me-2"></i>@action.Label</a>
                }
            </div>
        }
    </div>

    @if (Model.SummaryCards.Any())
    {
        <div class="row g-4 mb-4">
            @foreach (var card in Model.SummaryCards)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="stat-card stat-@card.AccentClass">
                        <div class="stat-icon"><i class="@card.Icon"></i></div>
                        <div class="stat-content">
                            <span>@card.Title</span>
                            <strong>@card.Value</strong>
                            <p>@card.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="row g-4">
        @foreach (var detailSection in Model.Sections)
        {
            <div class="col-lg-6">
                <div class="panel-card h-100">
                    <div class="panel-card-header">
                        <div>
                            <h3>@detailSection.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(detailSection.Description))
                            {
                                <p>@detailSection.Description</p>
                            }
                        </div>
                    </div>
                    <div class="detail-grid">
                        @foreach (var item in detailSection.Items)
                        {
                            <div class="detail-item">
                                <span>@item.Label</span>
                                @if (item.IsBadge)
                                {
                                    <strong><span class="badge @item.BadgeClass">@item.Value</span></strong>
                                }
                                else
                                {
                                    <strong>@item.Value</strong>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.Timeline.Any())
    {
        <div class="panel-card mt-4">
            <div class="panel-card-header">
                <div>
                    <h3>Dòng thời gian</h3>
                    <p>Ghi chú vận hành và các mốc xử lý liên quan.</p>
                </div>
            </div>
            <div class="timeline-list">
                @foreach (var item in Model.Timeline)
                {
                    <div class="timeline-item">
                        <span class="timeline-dot bg-@item.AccentClass"></span>
                        <div>
                            <div class="d-flex gap-2 align-items-center mb-1">
                                <strong>@item.Title</strong>
                                <span class="text-muted small">@item.Meta</span>
                            </div>
                            <p class="mb-0 text-secondary">@item.Description</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
