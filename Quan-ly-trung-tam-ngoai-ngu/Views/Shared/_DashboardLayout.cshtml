@{
    var pageModel = ViewData.Model as AppPageViewModel;
    var pageTitle = ViewData["Title"]?.ToString() ?? pageModel?.Title ?? "Bảng điều khiển";
    var rawRole = Context.Session.GetString("DemoUserRole");
    var displayName = Context.Session.GetString("DemoUserDisplayName") ?? "người dùng";
    var currentArea = (ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var roleLabel = rawRole switch
    {
        "Admin" => "Quản trị viên",
        "Staff" => "Giáo vụ",
        "Teacher" => "Giáo viên",
        _ => "Người dùng"
    };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - NorthStar English</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dashboard-shell">
    <aside class="dashboard-sidebar">
        @await Html.PartialAsync("~/Views/Shared/Partials/_DashboardSidebar.cshtml")
    </aside>

    <div class="dashboard-main">
        <header class="dashboard-header">
            <div>
                <span class="dashboard-role-badge">@roleLabel</span>
                <div class="dashboard-greeting">Xin chào, @displayName</div>
                <div class="dashboard-role">Theo dõi dữ liệu, thao tác nhanh và cập nhật luôn nội dung hiển thị ngoài trang chủ trong cùng một khu quản trị.</div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                @if (currentArea == "admin")
                {
                    <a class="btn btn-outline-primary btn-sm" href="/Admin/News">
                        <i class="bi bi-newspaper me-2"></i>Tin tức trang chủ
                    </a>
                }
                <a class="btn btn-outline-primary btn-sm" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door me-2"></i>Trang chủ công khai
                </a>
                <a class="btn btn-light btn-sm" asp-area="" asp-controller="Profile" asp-action="Index">
                    <i class="bi bi-person me-2"></i>Hồ sơ
                </a>
                <a class="btn btn-dark btn-sm" asp-area="" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
            </div>
        </header>

        <main class="dashboard-content">
            @RenderBody()
        </main>
    </div>

    @await Html.PartialAsync("~/Views/Shared/Partials/_Toast.cshtml")
    @await Html.PartialAsync("~/Views/Shared/Partials/_ConfirmModal.cshtml")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
