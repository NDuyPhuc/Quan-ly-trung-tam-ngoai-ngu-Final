@model ContactViewModel
@{
    var sectionTitle = ViewData["ContactSectionTitle"]?.ToString() ?? "Liên hệ NorthStar English";
    var sectionSubtitle = ViewData["ContactSectionSubtitle"]?.ToString() ?? "Để lại thông tin chi tiết để trung tâm tư vấn đúng khóa học, khung giờ và lộ trình phù hợp nhất cho bạn.";
    var formTitle = ViewData["ContactFormTitle"]?.ToString() ?? "Gửi yêu cầu tư vấn chi tiết";
    var formSubtitle = ViewData["ContactFormSubtitle"]?.ToString() ?? "Điền càng rõ nhu cầu, trung tâm càng dễ tư vấn đúng lớp, mức học phí và lịch học phù hợp cho bạn.";
    var supportEmail = ViewData["SupportEmail"]?.ToString() ?? "nguyenthanhdanhctk42@gmail.com";
    var supportPhone = ViewData["SupportPhone"]?.ToString() ?? "0901 001 001";
    var supportHours = ViewData["SupportHours"]?.ToString() ?? "08:00 - 20:30 mỗi ngày";
}

<section class="page-section page-section-spacious">
    <div class="container">
        @await Html.PartialAsync("~/Views/Shared/Partials/_Breadcrumbs.cshtml", Model.Breadcrumbs)

        <div class="catalog-hero-card">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6">
                    <span class="landing-label">Liên hệ tư vấn</span>
                    <h1>@sectionTitle</h1>
                    <p class="page-subtitle">@sectionSubtitle</p>
                    <div class="hero-chip-row">
                        <span class="info-pill">Hotline @supportPhone</span>
                        <span class="info-pill">Tư vấn TOEIC - IELTS - Giao tiếp</span>
                        <span class="info-pill">Hỗ trợ @supportHours</span>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="catalog-hero-media">
                        <img src="@AppUi.PublicImageUrl("contact")" alt="Minh họa tư vấn học viên" />
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="contact-info-stack">
                    <div class="contact-info-card">
                        <span class="contact-info-icon"><i class="bi bi-telephone"></i></span>
                        <strong>Hotline tư vấn</strong>
                        <p>@supportPhone<br />Hỗ trợ nhanh qua cuộc gọi và Zalo.</p>
                    </div>
                    <div class="contact-info-card">
                        <span class="contact-info-icon"><i class="bi bi-envelope"></i></span>
                        <strong>Email nhận yêu cầu</strong>
                        <p>@supportEmail<br />Nhận thông tin đăng ký và yêu cầu tư vấn chi tiết.</p>
                    </div>
                    <div class="contact-info-card">
                        <span class="contact-info-icon"><i class="bi bi-geo-alt"></i></span>
                        <strong>Khu vực hỗ trợ</strong>
                        <p>Tư vấn học trực tiếp, trực tuyến và lớp doanh nghiệp theo nhu cầu.</p>
                    </div>
                    <div class="contact-info-card">
                        <span class="contact-info-icon"><i class="bi bi-clock"></i></span>
                        <strong>Khung giờ phản hồi</strong>
                        <p>@supportHours.<br />Ưu tiên liên hệ trong vòng 24 giờ.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="form-display-card">
                    <div class="landing-section-header contact-header">
                        <div>
                            <h2>@formTitle</h2>
                            <p>@formSubtitle</p>
                        </div>
                    </div>
                    @await Html.PartialAsync("~/Views/Shared/Partials/_ContactInquiryForm.cshtml", Model, new ViewDataDictionary(ViewData)
                    {
                        ["ReturnUrl"] = "/Contact",
                        ["SubmitLabel"] = "Gửi yêu cầu tư vấn",
                        ["SupportEmail"] = supportEmail
                    })
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
